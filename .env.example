# ─────────────────────────────────────────────────────────────────────────────
# Claude / Anthropic
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override if using a corporate LLM gateway or regional proxy.
# Leave commented out to use the default Anthropic endpoint.
# ANTHROPIC_BASE_URL=https://your-internal-llm-gateway.com

# ─────────────────────────────────────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-3-7-sonnet-20250219
MAX_TOKENS=4096
MAX_RETRIES=2

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOCAL_DATA_DIR=local_data
